# LLM provider (Phase 4+) — Groq
GROQ_API_KEY=
# llama-3.1-8b-instant uses fewer tokens and is cheaper than llama-3.3-70b-versatile
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=120
GROQ_MAX_CHUNKS=2
GROQ_MAX_FUND_MANAGEMENT_CHUNKS=3

# Embedding model (Phase 1+)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Vector store (Phase 1+)
CHROMA_PERSIST_DIR=data/index

# Corpus config
CORPUS_CONFIG_PATH=config/corpus.yaml

# Scheduler (Phase 7+)
SCHEDULER_HOUR=10
SCHEDULER_MINUTE=0
SCHEDULER_TIMEZONE=Asia/Kolkata
SCHEDULER_RETRY_ON_FAILURE=true
INDEX_STAGING_DIR=data/index_staging

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:8000,http://127.0.0.1:8000
RATE_LIMIT_PER_MINUTE=60
ENV=development
